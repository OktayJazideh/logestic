generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  COOP
  EMPLOYER
  DRIVER
  FLEET_OWNER
  HOUSEHOLD
  CONSULTANT
}

enum HouseholdStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
  NEEDS_CORRECTION
}

enum LoadStatus {
  PENDING
  IN_TRANSIT
  DELIVERED
  CANCELED
}

enum MissionStatus {
  ASSIGNED
  LOADING
  ON_THE_WAY
  UNLOADING
  COMPLETED
  APPROVED
  REJECTED
  CANCELED
}

enum WeighbridgeTicketStatus {
  PENDING_EMPTY
  EMPTY_REGISTERED
  LOADED_REGISTERED
  APPROVED
  REJECTED
  ADJUSTED
}

enum MissionPaymentState {
  PENDING
  CALCULATED
  DISTRIBUTED
  SETTLED
  HELD
  FAILED
}

enum HourlyWorkLogStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SettlementBatchStatus {
  DRAFT
  LOCKED
  PAID
  CANCELLED
}

enum PaymentPayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum WeighbridgeAdjustmentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum WalletType {
  OWNER
  HOUSEHOLD
  PLATFORM
}

enum TransactionType {
  CREDIT
  DEBIT
}

model users {
  id            BigInt @id @default(autoincrement())
  mobile_number String @unique
  password_hash String
  role          UserRole
  is_active     Boolean @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  households  households?
  drivers     drivers?
  fleet_owners fleet_owners?
  consultant_hourly_logs hourly_work_logs[] @relation("HourlyLogConsultant")
}

model mines {
  id                     BigInt @id @default(autoincrement())
  mine_code              String @unique
  name                    String
  location_coordinates    String?
  created_at             DateTime @default(now())
  updated_at             DateTime @updatedAt

  villages villages[]
  loads loads[]
  rate_cards rate_cards[]
  hourly_work_logs hourly_work_logs[]
  settlement_batches settlement_batches[]
}

model rate_cards {
  id             BigInt    @id @default(autoincrement())
  mine_id        BigInt
  material_type  String
  rate_per_ton   Decimal   @db.Decimal(15, 4)
  valid_from     DateTime
  valid_to       DateTime?
  created_at     DateTime  @default(now())

  mine     mines      @relation(fields: [mine_id], references: [id])
  missions missions[]

  @@index([mine_id])
  @@index([mine_id, material_type])
}

model villages {
  id         BigInt @id @default(autoincrement())
  mine_id    BigInt
  name       String
  district   String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  mine        mines         @relation(fields: [mine_id], references: [id])
  households  households[]

  @@index([mine_id])
}

model households {
  id          BigInt @id @default(autoincrement())
  user_id     BigInt @unique
  village_id  BigInt
  head_name   String
  national_id String @unique
  bank_iban   String?
  quota_limit Int?
  status      HouseholdStatus @default(PENDING)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  user    users @relation(fields: [user_id], references: [id])
  village villages @relation(fields: [village_id], references: [id])
  loads   loads[]
  wallets wallets[]
  hourly_work_logs hourly_work_logs[]
}

model fleet_owners {
  id          BigInt @id @default(autoincrement())
  user_id     BigInt @unique
  full_name   String
  national_id String @unique
  bank_iban   String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  user users @relation(fields: [user_id], references: [id])
  vehicles vehicles[]
  missions missions[]
  hourly_work_logs hourly_work_logs[]
  wallets wallets[]
}

model drivers {
  id             BigInt @id @default(autoincrement())
  user_id        BigInt @unique
  full_name      String
  license_number String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  user users @relation(fields: [user_id], references: [id])
  missions missions[]
}

model vehicles {
  id            BigInt @id @default(autoincrement())
  owner_id      BigInt
  license_plate String @unique
  vehicle_type  String
  capacity_tons Decimal @db.Decimal(5, 2)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  owner fleet_owners @relation(fields: [owner_id], references: [id])
  hourly_work_logs hourly_work_logs[]
  missions missions[]

  @@index([owner_id])
}

model loads {
  id                BigInt @id @default(autoincrement())
  load_tracking_code String @unique
  mine_id           BigInt
  household_id      BigInt
  material_type    String
  status            LoadStatus @default(PENDING)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  mine mines @relation(fields: [mine_id], references: [id])
  household households @relation(fields: [household_id], references: [id])
  missions missions[]

  @@index([mine_id])
  @@index([household_id])
}

model missions {
  id        BigInt @id @default(autoincrement())
  load_id   BigInt
  owner_id  BigInt
  driver_id BigInt
  vehicle_id BigInt
  status    MissionStatus @default(ASSIGNED)
  started_at DateTime?
  completed_at DateTime?
  rate_card_id BigInt?
  rate_per_ton_snapshot Decimal? @db.Decimal(15, 4)
  material_type_snapshot String?
  payment_state MissionPaymentState @default(PENDING)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  load loads @relation(fields: [load_id], references: [id])
  owner fleet_owners @relation(fields: [owner_id], references: [id])
  driver drivers @relation(fields: [driver_id], references: [id])
  vehicle vehicles @relation(fields: [vehicle_id], references: [id])
  rate_card rate_cards? @relation(fields: [rate_card_id], references: [id])

  weighbridge_tickets weighbridge_tickets?
  transactions transactions[]
  settlement_lines settlement_lines[]
  weighbridge_adjustment_requests weighbridge_adjustment_requests[]

  @@index([load_id])
  @@index([rate_card_id])
}

model weighbridge_tickets {
  id            BigInt @id @default(autoincrement())
  mission_id   BigInt @unique
  ticket_number String @unique
  empty_weight Decimal @db.Decimal(10, 2)
  loaded_weight Decimal @db.Decimal(10, 2)
  net_weight   Decimal @db.Decimal(10, 2)
  status       WeighbridgeTicketStatus @default(PENDING_EMPTY)
  created_by_user_id BigInt?
  approved_by_user_id BigInt?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  mission missions @relation(fields: [mission_id], references: [id])
  weighbridge_adjustment_requests weighbridge_adjustment_requests[]
}

model wallets {
  id         BigInt @id @default(autoincrement())
  wallet_type WalletType
  owner_id    BigInt?
  household_id BigInt?
  platform_owner_key String? // for future
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  owner fleet_owners? @relation(fields: [owner_id], references: [id])
  household households? @relation(fields: [household_id], references: [id])
  transactions transactions[]
  settlement_lines settlement_lines[]
}

model transactions {
  id          BigInt @id @default(autoincrement())
  wallet_id   BigInt
  mission_id  BigInt?
  amount      Decimal @db.Decimal(15, 2)
  type        TransactionType
  description String?
  created_at  DateTime @default(now())

  wallet wallets @relation(fields: [wallet_id], references: [id])
  mission missions? @relation(fields: [mission_id], references: [id])

  @@index([wallet_id])
  @@index([mission_id])
}

model hourly_work_logs {
  id                   BigInt   @id @default(autoincrement())
  mine_id              BigInt
  fleet_owner_id       BigInt
  vehicle_id           BigInt?
  household_id         BigInt?
  hours                Decimal  @db.Decimal(10, 2)
  hourly_rate_snapshot Decimal  @db.Decimal(15, 4)
  status               HourlyWorkLogStatus @default(PENDING)
  consultant_user_id   BigInt?
  approved_at          DateTime?
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  mine  mines        @relation(fields: [mine_id], references: [id])
  owner fleet_owners @relation(fields: [fleet_owner_id], references: [id])
  vehicle vehicles?  @relation(fields: [vehicle_id], references: [id])
  household households? @relation(fields: [household_id], references: [id])
  consultant users? @relation("HourlyLogConsultant", fields: [consultant_user_id], references: [id])

  settlement_lines settlement_lines[]

  @@index([mine_id])
  @@index([fleet_owner_id])
  @@index([household_id])
  @@index([consultant_user_id])
}

model settlement_batches {
  id                 BigInt               @id @default(autoincrement())
  mine_id            BigInt?
  period_start       DateTime
  period_end         DateTime
  status             SettlementBatchStatus @default(DRAFT)
  created_by_user_id BigInt?
  locked_at          DateTime?
  paid_at            DateTime?
  cancelled_at       DateTime?
  payment_reference  String?
  created_at         DateTime             @default(now())
  updated_at         DateTime             @updatedAt

  mine             mines?             @relation(fields: [mine_id], references: [id])
  lines            settlement_lines[]
  payment_payout   payment_payouts?

  @@index([mine_id])
}

model settlement_lines {
  id                 BigInt  @id @default(autoincrement())
  batch_id           BigInt
  wallet_id          BigInt
  amount             Decimal @db.Decimal(15, 2)
  mission_id         BigInt?
  hourly_work_log_id BigInt?
  note               String?

  batch           settlement_batches @relation(fields: [batch_id], references: [id], onDelete: Cascade)
  wallet          wallets           @relation(fields: [wallet_id], references: [id])
  mission         missions?         @relation(fields: [mission_id], references: [id])
  hourly_work_log hourly_work_logs? @relation(fields: [hourly_work_log_id], references: [id])

  @@index([batch_id])
  @@index([hourly_work_log_id])
}

model payment_payouts {
  id                  BigInt              @id @default(autoincrement())
  settlement_batch_id BigInt              @unique
  status              PaymentPayoutStatus @default(PENDING)
  initiated_at        DateTime?
  completed_at        DateTime?
  bank_reference      String?
  failure_reason      String?
  created_at          DateTime            @default(now())
  updated_at          DateTime            @updatedAt

  settlement_batch settlement_batches @relation(fields: [settlement_batch_id], references: [id], onDelete: Cascade)

  @@index([status])
}

model weighbridge_adjustment_requests {
  id                     BigInt                       @id @default(autoincrement())
  ticket_id              BigInt
  mission_id             BigInt
  reason                 String
  before_net             Decimal                      @db.Decimal(10, 2)
  after_net              Decimal                      @db.Decimal(10, 2)
  status                 WeighbridgeAdjustmentStatus  @default(PENDING)
  requested_by_user_id   BigInt
  approved_by_user_id    BigInt?
  created_at             DateTime                     @default(now())

  ticket  weighbridge_tickets @relation(fields: [ticket_id], references: [id])
  mission missions           @relation(fields: [mission_id], references: [id])

  @@index([ticket_id])
  @@index([mission_id])
}

model audit_logs {
  id             BigInt @id @default(autoincrement())
  entity_type    String
  entity_id      String
  action         String
  before_value   Json?
  after_value    Json?
  performed_by_user_id BigInt?
  reason         String?
  created_at     DateTime @default(now())

  @@index([entity_type, entity_id])
}

