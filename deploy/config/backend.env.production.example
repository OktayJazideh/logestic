# /etc/logestic/backend.env — production hamsahman.ir (DEPLOY-SAHMAN-1)
# Copy to VPS: sudo cp deploy/config/backend.env.production.example /etc/logestic/backend.env
# Then: sudo nano /etc/logestic/backend.env  (set SMS_API_KEY + DATABASE_URL)
# sudo chmod 600 /etc/logestic/backend.env

NODE_ENV=production
PORT=4000

# Postgres on same VPS (adjust password)
DATABASE_URL=postgresql://mineral:CHANGE_ME@127.0.0.1:5434/mineral_mvp

# SMS — Kavenegar
SMS_PROVIDER=kavenegar
SMS_API_KEY=YOUR_KAVENEGAR_API_KEY
SMS_SENDER_LINE=2000660110
# خط اشتراکی/بین‌المللی: OTP فقط با lookup + قالب از پنل (نه sms/send)
# پنل → اعتبارسنجی → الگوها → نام انگلیسی قالب (مثلاً loginverify)
SMS_OTP_TEMPLATE=YOUR_LOOKUP_TEMPLATE_NAME

# Public site (no trailing slash) — QR رسید PDF
PUBLIC_URL=https://hamsahman.ir
PLATFORM_NAME=همسهمان

# Behind nginx
TRUST_PROXY=true
CORS_ORIGINS=https://hamsahman.ir,https://www.hamsahman.ir

DISPATCH_MODE=manual
BANK_ADAPTER=mock

# Production: OTP-only login. Set true only for temporary UAT on production domain.
ENABLE_DEMO_LOGIN=false

# Optional: test mobile for npm run test:sms-prod1 -- --live
# SMS_TEST_MOBILE=09XXXXXXXXX
